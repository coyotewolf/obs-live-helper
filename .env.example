PORT=5172
CLIENT_ID=your_spotify_client_id
REDIRECT_URI=http://127.0.0.1:5172/api/spotify/callback

# Optional. If empty, the helper generates and stores these locally in storage/security.json.
ADMIN_TOKEN=
REQUEST_PIN=

# Optional public audience URL via Cloudflare Quick Tunnel.
# Recommended: leave false, then start/stop the tunnel from Dashboard.
ENABLE_PUBLIC_TUNNEL=false

# Optional explicit path if cloudflared is not in PATH.
# Examples:
# Windows: C:\Users\YourName\Downloads\cloudflared.exe
# macOS/Linux: /usr/local/bin/cloudflared
CLOUDFLARED_PATH=
CLOUDFLARED_VERSION=2025.8.1
