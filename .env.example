PORT=5172
CLIENT_ID=your_spotify_client_id
REDIRECT_URI=http://127.0.0.1:5172/api/spotify/callback

# Optional. If empty, the helper will generate and store these in storage/security.json.
ADMIN_TOKEN=
REQUEST_PIN=

# Free public audience URL via Cloudflare Quick Tunnel.
# Requires cloudflared installed on the host machine.
ENABLE_PUBLIC_TUNNEL=false
